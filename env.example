# ── Fastlink WhatsApp Bridge — environment variables ──
# Copy these into your host's "Environment" settings (Render/Railway).
# Do NOT commit real values to GitHub.

# A password you invent. You'll paste the SAME value into Meta's webhook "Verify token" field.
VERIFY_TOKEN=fastlink_verify_2026

# Meta System User access token (from Meta Business Suite → System Users).
# Set it to "never expire" so you don't have to rotate it.
WA_TOKEN=PASTE_YOUR_META_ACCESS_TOKEN

# Meta Phone Number ID for the number +255750611611
# (found in Meta App → WhatsApp → API Setup, NOT the phone number itself).
PHONE_ID=PASTE_YOUR_PHONE_NUMBER_ID

# Your Firebase Realtime Database URL (already correct for Fastlink).
FB_URL=https://fastlinksafaris-d6f22-default-rtdb.europe-west1.firebasedatabase.app

# Graph API version (leave as-is unless Meta tells you otherwise).
GRAPH_VERSION=v21.0

# How often (ms) to check for staff replies to send. 4000 = every 4 seconds.
POLL_MS=4000
